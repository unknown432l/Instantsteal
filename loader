local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- [[ BYPASS ANTI-KICK DELTA ]]
local gmt = getrawmetatable(game)
setreadonly(gmt, false)
local oldIndex = gmt.__index
gmt.__index = newcclosure(function(self, key)
    if tostring(self) == "LocalPlayer" and key == "Kick" then
        return function() warn("Delta Anti-Kick: Bloqueado.") end
    end
    return oldIndex(self, key)
end)
setreadonly(gmt, true)

-- Variable global para almacenar la posición
local PosicionGuardada = nil

-- [[ INTERFAZ GRÁFICA RESISTENTE ]]
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local UIListLayout = Instance.new("UIListLayout")
local SetPosButton = Instance.new("TextButton")
local EscaparButton = Instance.new("TextButton")
local UICorner1 = Instance.new("UICorner")
local UICorner2 = Instance.new("UICorner")

ScreenGui.Name = "EscapeBrainrotUltra"
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

MainFrame.Parent = ScreenGui
MainFrame.Size = UDim2.new(0, 200, 0, 115)
MainFrame.Position = UDim2.new(0.5, -100, 0.15, 0)
MainFrame.BackgroundTransparency = 1
MainFrame.Active = true
MainFrame.Draggable = true

UIListLayout.Parent = MainFrame
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
UIListLayout.Padding = UDim.new(0, 10)

SetPosButton.Name = "SetPosButton"
SetPosButton.Parent = MainFrame
SetPosButton.Size = UDim2.new(1, 0, 0, 50)
SetPosButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
SetPosButton.TextColor3 = Color3.fromRGB(255, 255, 255)
SetPosButton.TextSize = 16
SetPosButton.Font = Enum.Font.GothamBold
SetPosButton.Text = "📌 GUARDAR MI BASE"
SetPosButton.LayoutOrder = 1

UICorner1.CornerRadius = UDim.new(0, 12)
UICorner1.Parent = SetPosButton

EscaparButton.Name = "EscapeButton"
EscaparButton.Parent = MainFrame
EscaparButton.Size = UDim2.new(1, 0, 0, 50)
EscaparButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
EscaparButton.TextColor3 = Color3.fromRGB(255, 255, 255)
EscaparButton.TextSize = 16
EscaparButton.Font = Enum.Font.GothamBold
EscaparButton.Text = "💨 ESCAPAR CON BOTÍN"
EscaparButton.LayoutOrder = 2

UICorner2.CornerRadius = UDim.new(0, 12)
UICorner2.Parent = EscaparButton

-- [[ LÓGICA DE GUARDADO ]]
SetPosButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        -- Guarda tu posición exacta tocando la alfombra de cobro
        PosicionGuardada = rootPart.CFrame 
        SetPosButton.Text = "✅ ¡BASE CONFIGURADA!"
        SetPosButton.BackgroundColor3 = Color3.fromRGB(0, 180, 90)
        task.wait(1.5)
        SetPosButton.Text = "📌 ACTUALIZAR BASE"
        SetPosButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    end
end)

-- [[ LÓGICA DE TELETRANSPORTE POR DESLIZAMIENTO SEGURO ]]
EscaparButton.MouseButton1Click:Connect(function()
    if not PosicionGuardada then
        EscaparButton.Text = "❌ CONFIGURA TU BASE PRIMERO"
        task.wait(1.5)
        EscaparButton.Text = "💨 ESCAPAR CON BOTÍN"
        return
    end

    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if rootPart and character then
        EscaparButton.Text = "⚡ VIAJANDO A BASE..."
        EscaparButton.BackgroundColor3 = Color3.fromRGB(0, 180, 90)
        
        -- 1. Desactivamos la gravedad del personaje un momento para que no se choque con paredes al volar
        rootPart.Velocity = Vector3.new(0,0,0)
        rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
        
        -- 2. Creamos un deslizamiento ultra veloz (Tween) hacia tu base
        -- Esto engaña al servidor haciéndole creer que caminaste rápido, manteniendo el Brainrot amarrado legalmente
        local distancia = (rootPart.Position - PosicionGuardada.Position).Magnitude
        local tiempoViaje = distancia / 450 -- Velocidad calculada (ajustada para saltar anticheats de velocidad)
        
        local tweenInfo = TweenInfo.new(tiempoViaje, Enum.EasingStyle.Linear)
        local moverPersonaje = TweenService:Create(rootPart, tweenInfo, {CFrame = PosicionGuardada})
        
        moverPersonaje:Play()
        
        -- 3. Al llegar a la alfombra, se detiene y activa el cobro natural del juego
        moverPersonaje.Completed:Connect(function()
            rootPart.Velocity = Vector3.new(0,0,0)
            rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
            
            -- Te deja libre en tu base
            EscaparButton.Text = "💨 ESCAPAR CON BOTÍN"
            EscaparButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
            print("¡Llegada exitosa! El juego debería procesar el 'You Stole' ahora.")
        end)
    end
end)
