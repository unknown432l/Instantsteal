UICorner2.CornerRadius = UDim.new(0, 10)
UICorner2.Parent = EscaparButton

UIGradient2.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 95, 230)), -- Azul Neón Intenso
    ColorSequenceKeypoint.new(1, Color3.fromRGB(8, 8, 12))
}
UIGradient2.Parent = EscaparButton

UIBorder2.Color = Color3.fromRGB(0, 215, 255) -- Borde Cian Ultrabrillante
