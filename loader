-- [[ LOGICA DE ESCANEO DE LA ALFOMBRA DE COBRO ]]
SetPosButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        PosicionGuardada = rootPart.CFrame
        local raycastParams = RaycastParams.new()
        local ray = workspace:Raycast(rootPart.Position, Vector3.new(0, -10, 0), raycastParams)
        if ray and ray.Instance then
            MiAlfombraRoja = ray.Instance
            SetPosButton.Text = "✅ BASE VINCULADA"
            UIBorder1.Color = Color3.fromRGB(0, 255, 120)
            task.wait(1.5)
            SetPosButton.Text = "📌 ACTUALIZAR SENSOR"
            UIBorder1.Color = Color3.fromRGB(0, 160, 255)
        end
    end
end)

-- [[ LOGICA DE FUERZA BRUTA: TP + RE-SET DE FÍSICAS ]]
EscaparButton.MouseButton1Click:Connect(function()
    if not PosicionGuardada or not MiAlfombraRoja then
        EscaparButton.Text = "❌ CONFIGURA TU BASE PRIMERO"
        task.wait(1.5)
        EscaparButton.Text = "⚡ ESCAPAR CON BOTÍN"
        return
    end

    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if rootPart and character and humanoid then
        EscaparButton.Text = "⚡ COMPLETANDO ROBO..."
        
        -- 1. Forzar la simulación de red local para adueñarnos del objeto amarrado
        local brainrot = character:FindFirstChild("Brainrot") or character:FindFirstChildOfClass("Tool")
        if brainrot then
            pcall(function()
                settings().Physics.AllowSleep = false
                brainrot:SetAttribute("NetworkOwner", LocalPlayer)
            end)
        end

        -- 2. Teletransporte Hard-CFrame instantáneo de tu cuerpo a la alfombra
        rootPart.Velocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.CFrame = PosicionGuardada
        
        -- 3. Inyección directa al sensor de la alfombra (Fuerza el cartel de "You Stole")
        local handle = brainrot and (brainrot:FindFirstChild("Handle") or brainrot)
        if handle then
            firetouchtransmitter(MiAlfombraRoja, handle, 0)
            task.wait(0.01)
            firetouchtransmitter(MiAlfombraRoja, handle, 1)
        end
        
        -- 4. HARD LOCK LOOP: Congela la posición por 0.5 segundos para que la soga no actúe y el server guarde el objeto en tus máquinas
        rootPart.Anchored = true
        for i = 1, 15 do
            rootPart.CFrame = PosicionGuardada
            rootPart.Velocity = Vector3.new(0, 0, 0)
            humanoid:ChangeState(Enum.HumanoidStateType.Freefall) -- Desactiva la soga simulando caída libre
            task.wait(0.03)
        end
        rootPart.Anchored = false -- Te suelta libre en tu base ya con tu dinero procesado
        
        EscaparButton.Text = "⚡ ESCAPAR CON BOTÍN"
    end
end)
