UIBorder2.Parent = EscaparButton

-- [[ LÓGICA DE DETECCIÓN Y GUARDADO DE COORDENADAS ]]
SetPosButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        PosicionGuardada = rootPart.CFrame
        SetPosButton.Text = "✅ COORDENADA GUARDADA"
        UIBorder1.Color = Color3.fromRGB(0, 255, 120) -- Verde temporal de éxito
        task.wait(1.5)
        SetPosButton.Text = "📌 ACTUALIZAR COORDENADA"
        UIBorder1.Color = Color3.fromRGB(0, 160, 255)
    end
end)

-- [[ LÓGICA ULTRA RÁPIDA: DESINCRONIZACIÓN DE RED + TELEPORT ]]
EscaparButton.MouseButton1Click:Connect(function()
    if not PosicionGuardada then
        EscaparButton.Text = "❌ MARCA TU COORDENADA PRIMERO"
        task.wait(1.5)
        EscaparButton.Text = "⚡ ESCAPAR A COORDENADA"
        return
    end

    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    
    if rootPart and humanoid and backpack and humanoid.Health > 0 then
        EscaparButton.Text = "⚡ ENTREGANDO..."
        EscaparButton.TextColor3 = Color3.fromRGB(0, 255, 160)
        
        -- Identificamos el Brainrot en tu mano
        local brainrot = character:FindFirstChildOfClass("Tool") or character:FindFirstChild("Brainrot")
        
        -- MUDANZA ULTRA RÁPIDA DE PACKETS: Camufla el objeto en la mochila antes del TP
        if brainrot and brainrot:IsA("Tool") then
            brainrot.Parent = backpack
        end
        
        -- DESINCRONIZACIÓN DE RED: Borra sogas y se adueña de la física local
        pcall(function()
            for _, obj in pairs(character:GetDescendants()) do
                if obj:IsA("RopeConstraint") or obj:IsA("SpringConstraint") or obj:IsA("Constraint") or obj:IsA("BodyMover") then
                    obj:Destroy()
                end
            end
            settings().Physics.AllowSleep = false
            if brainrot then
                brainrot:SetAttribute("NetworkOwner", LocalPlayer)
            end
        end)
        
        -- ANULACIÓN DE VECTORES (Velocity Nulling) + TELEPORT MANUAL
        rootPart.Velocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        rootPart.CFrame = PosicionGuardada
        task.wait(0.02)
        
        -- EXTRACCIÓN Y DEPOSITO FÍSICO EN LA COORDENADA GUARDADA
        local botin = backpack:FindFirstChildOfClass("Tool") or character:FindFirstChildOfClass("Tool")
        if botin then
            botin.Parent = character
            task.wait(0.01)
            botin.Parent = workspace -- Lo suelta en tu alfombra para forzar el impacto legal
            if botin:FindFirstChild("Handle") then
                botin.Handle.CFrame = PosicionGuardada
            end
        end
        
        -- HARD LOCK DE REDUNDANCIA: Te mantiene amarrado en tus coordenadas para anular fuerzas de regreso
        rootPart.Anchored = true
        for i = 1, 15 do
            rootPart.CFrame = PosicionGuardada
            if botin and botin:FindFirstChild("Handle") then
                botin.Handle.CFrame = PosicionGuardada
            end
            humanoid:ChangeState(Enum.HumanoidStateType.Freefall) -- Evita el cálculo de la soga del servidor
            task.wait(0.03)
        end
        rootPart.Anchored = false
        
        EscaparButton.Text = "⚡ ESCAPAR A COORDENADA"
        EscaparButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end)
