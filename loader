-- [[ LÓGICA DE DETECCIÓN Y GUARDADO ]]
SetPosButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        PosicionGuardada = rootPart.CFrame
        
        local raycastParams = RaycastParams.new()
        local ray = workspace:Raycast(rootPart.Position, Vector3.new(0, -10, 0), raycastParams)
        if ray and ray.Instance then
            MiZonaDeEntrega = ray.Instance
        end
        
        SetPosButton.Text = "✅ ¡BASE GUARDADA!"
        UIBorder1.Color = Color3.fromRGB(0, 255, 120) -- Borde Verde Neón temporal de éxito
        task.wait(1.5)
        SetPosButton.Text = "📌 ACTUALIZAR BASE"
        UIBorder1.Color = Color3.fromRGB(0, 160, 255) -- Regresa al Azul Neón
    end
end)

-- [[ MOTOR FUERTE ANTI-JALÓN (ESTILO VECTOR NULLIFY + INYECCIÓN) ]]
EscaparButton.MouseButton1Click:Connect(function()
    if not PosicionGuardada then
        EscaparButton.Text = "❌ CONFIGURA TU BASE PRIMERO"
        task.wait(1.5)
        EscaparButton.Text = "⚡ ESCAPAR CON BOTÍN"
        return
    end

    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if rootPart and character and humanoid then
        EscaparButton.Text = "📡 CORRIENDO TRUCO..."
        
        -- 1. DETECCIÓN Y DESANCLAJE DE RESORTES: Destruye los cables del juego de inmediato
        for _, obj in pairs(character:GetDescendants()) do
            if obj:IsA("Constraint") or obj:IsA("BodyMover") or obj:IsA("RopeConstraint") or obj:IsA("SpringConstraint") then
                obj:Destroy()
            end
        end
        
        -- 2. BUSCAR PARTE FÍSICA DEL BOTÍN
        local brainrotPart = character:FindFirstChild("Brainrot") or character:FindFirstChildOfClass("Tool")
        if brainrotPart and brainrotPart:FindFirstChild("Handle") then
            brainrotPart = brainrotPart.Handle
        elseif character:FindFirstChild("BackpackItem") then
            brainrotPart = character.BackpackItem
        end
        
        -- 3. INYECCIÓN FÍSICA DE COLISIÓN (Activa el cartel de 'You Stole')
        if MiZonaDeEntrega and brainrotPart then
            firetouchtransmitter(MiZonaDeEntrega, brainrotPart, 0)
            task.wait(0.01)
            firetouchtransmitter(MiZonaDeEntrega, brainrotPart, 1)
        end
        
        -- 4. TELETRANSPORTE HARD CFRAME (Freno absoluto de vectores de velocidad)
        rootPart.Velocity = Vector3.new(0,0,0)
        rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0,0,0)
        rootPart.CFrame = PosicionGuardada
        
        -- 5. BUCLE DE REDUNDANCIA: Congela tu red por microsegundos para evitar que el server te jale
        rootPart.Anchored = true
        for i = 1, 12 do
            rootPart.CFrame = PosicionGuardada
            humanoid:ChangeState(Enum.HumanoidStateType.Freefall) -- Resetea la animación para engañar las físicas
            task.wait(0.02)
        end
        rootPart.Anchored = false
        
        EscaparButton.Text = "⚡ ESCAPAR CON BOTÍN"
    end
end)
