local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- [[ BYPASS ANTI-KICK DELTA ]]
local gmt = getrawmetatable(game)
setreadonly(gmt, false)
local oldIndex = gmt.__index
gmt.__index = newcclosure(function(self, key)
    if tostring(self) == "LocalPlayer" and key == "Kick" then
        return function() warn("Delta Anti-Kick: Intento de kick bloqueado.") end
    end
    return oldIndex(self, key)
end)
setreadonly(gmt, true)

-- [[ TU UBICACIÓN EXACTA MODIFICADA PARA TELEPORT SEGURO ]]
local MiBaseCoordenadas = CFrame.new(-177.102, -2.5, 6.132) 

-- [[ INTERFAZ DE UN BOTÓN ]]
local ScreenGui = Instance.new("ScreenGui")
local EscaparButton = Instance.new("TextButton")
local UICorner = Instance.new("UICorner")

ScreenGui.Name = "EscapeBrainrotMenu"
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

EscaparButton.Name = "EscapeButton"
EscaparButton.Parent = ScreenGui
EscaparButton.Size = UDim2.new(0, 180, 0, 60)
EscaparButton.Position = UDim2.new(0.5, -90, 0.15, 0)
EscaparButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
EscaparButton.TextColor3 = Color3.fromRGB(255, 255, 255)
EscaparButton.TextSize = 18
EscaparButton.Font = Enum.Font.GothamBold
EscaparButton.Text = "💨 ESCAPAR A BASE"
EscaparButton.Active = true
EscaparButton.Draggable = true

UICorner.CornerRadius = UDim.new(0, 12)
UICorner.Parent = EscaparButton

-- [[ ACCIÓN AL PRESIONAR EL BOTÓN ]]
EscaparButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        EscaparButton.Text = "¡TELEPORT!"
        rootPart.Velocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        
        -- Teletransporte seguro a tu zona
        rootPart.CFrame = MiBaseCoordenadas
        
        task.wait(1)
        EscaparButton.Text = "💨 ESCAPAR A BASE"
    end
end)
