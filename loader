-- [[ RASTREADOR AUTOMÁTICO DE TU ALFOMBRA ROJA ]]
local function ObtenerCFrameDeMiAlfombra()
    local tycoons = workspace:FindFirstChild("Tycoons") or workspace:FindFirstChild("Bases") or workspace:FindFirstChild("Plots") or workspace
    for _, tycoon in pairs(tycoons:GetChildren()) do
        local owner = tycoon:FindFirstChild("Owner") or tycoon:FindFirstChild("Player") or tycoon:FindFirstChild("OwnerValue")
        if owner and (owner.Value == LocalPlayer or owner.Value == LocalPlayer.Name or tycoon.Name == LocalPlayer.Name .. "'s Tycoon") then
            local dropPad = tycoon:FindFirstChild("DropZone") or tycoon:FindFirstChild("Deposit") or tycoon:FindFirstChild("Collector") or tycoon:FindFirstChild("Deliver") or tycoon:FindFirstChild("MainPart")
            if dropPad then
                return dropPad.CFrame
            end
            local spawnPad = tycoon:FindFirstChild("Spawn") or tycoon:FindFirstChild("SpawnPart")
            if spawnPad then
                return spawnPad.CFrame
            end
        end
    end
    return CFrame.new(0, 5, 0)
end

-- [[ LÓGICA ULTRA RÁPIDA: DESINCRONIZACIÓN DE RED + AUTO-DROP ]]
MainButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    
    if rootPart and humanoid and backpack and humanoid.Health > 0 then
        MainButton.Text = "⚡ ENTREGANDO..."
        MainButton.TextColor3 = Color3.fromRGB(0, 255, 160)
        
        -- 1. Buscamos el CFrame de tu alfombra automáticamente
        local destinoBase = ObtenerCFrameDeMiAlfombra()
        
        -- 2. Identificamos el Brainrot en tu mano
        local brainrot = character:FindFirstChildOfClass("Tool")
        
        -- 3. MUDANZA ULTRA RÁPIDA DE PACKETS: Esconde el objeto antes del TP para romper el elástico
        if brainrot then
            brainrot.Parent = backpack
        end
        
        -- 4. METODO MENCIONADO: Rompe las ataduras físicas y constraints del servidor en paralelo
        pcall(function()
            for _, obj in pairs(character:GetDescendants()) do
                if obj:IsA("RopeConstraint") or obj:IsA("SpringConstraint") or obj:IsA("Constraint") or obj:IsA("BodyMover") then
                    obj:Destroy()
                end
            end
            -- Fuerza la propiedad de simulación de red local para adueñarnos del objeto temporalmente
            settings().Physics.AllowSleep = false
            if brainrot then
                brainrot:SetAttribute("NetworkOwner", LocalPlayer)
            end
        end)
        
        -- 5. ANULACIÓN DE VECTORES DE VELOCIDAD (Velocity Nulling)
        rootPart.Velocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        rootPart.CFrame = destinoBase
        task.wait(0.02)
        
        -- 6. EXTRACCIÓN Y DEPOSITO FÍSICO EN TU BASE
        local botin = backpack:FindFirstChildOfClass("Tool") or character:FindFirstChildOfClass("Tool")
        if botin then
            botin.Parent = character
            task.wait(0.01)
            botin.Parent = workspace -- Lo suelta físicamente para forzar el impacto con tu alfombra
            if botin:FindFirstChild("Handle") then
                botin.Handle.CFrame = destinoBase
            end
        end
        
        -- 7. RE-ANCHORING & REDUNDANCIA DE RED: Clava la posición por milisegundos para registrar el 'You Stole'
        rootPart.Anchored = true
        for i = 1, 15 do
            rootPart.CFrame = destinoBase
            if botin and botin:FindFirstChild("Handle") then
                botin.Handle.CFrame = destinoBase
            end
            humanoid:ChangeState(Enum.HumanoidStateType.Freefall) -- Evita el cálculo de la soga del servidor
            task.wait(0.03)
        end
        rootPart.Anchored = false
        
        MainButton.Text = "⚡ ESCAPAR A BASE"
        MainButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end)
