UICorner1.Parent = SetPosButton

UIGradient1.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 40, 80)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 10, 12))
}
